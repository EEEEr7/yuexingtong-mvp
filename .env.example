# 阿里云百炼配置示例（不包含真实 key）
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-max

# DashScope Embedding（用于 Refiner 的标签增强：embedding + MMR 补足更贴切的 tags）
# 可选：不填则会自动复用 OPENAI_API_KEY；若你希望 embedding 单独走另一个 key/配额，再填写此项
DASHSCOPE_API_KEY=

# URL 抓取（Collector）可选：若本机 HTTPS/TLS 环境异常，可临时关闭证书校验（仅本地演示用）
COLLECTOR_SSL_VERIFY=true

# URL 抓取（Collector）可选：是否读取系统代理环境变量（HTTP_PROXY/HTTPS_PROXY 等）
# 若你机器存在“残留代理变量”导致 ProxyError，可设为 false（仅本地演示用）
COLLECTOR_TRUST_ENV=true

# 可选：当某些供应商的 chat.completions 路径与默认推断不一致时覆盖
# 例如：
# OPENAI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
# OPENAI_CHAT_COMPLETIONS_PATH=/chat/completions
# OPENAI_CHAT_COMPLETIONS_PATH=/openai/deployments/<deployment>/chat/completions?api-version=2024-xx-xx
OPENAI_CHAT_COMPLETIONS_PATH=

